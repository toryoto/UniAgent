# Hotelbeds API (https://developer.hotelbeds.com)
HOTELBEDS_API_KEY=your_api_key_here
HOTELBEDS_API_SECRET=your_api_secret_here
HOTELBEDS_BASE_URL=https://api.test.hotelbeds.com

# LangChain internal LLM
ANTHROPIC_API_KEY=your_anthropic_api_key

# Server
PORT=3004

# Registration (Pinata + on-chain)
PINATA_JWT=your_pinata_jwt
PRIVATE_KEY=your_private_key_with_or_without_0x
RPC_URL=https://sepolia.base.org
BASE_URL=http://localhost:3004
AGENT_RECEIVER_ADDRESS=0x_your_wallet_address

# Dev: skip x402 payment verification
X402_DISABLED=true

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": [],
    "typeRoots": []
  },
  "include": ["scripts/**/*"],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../packages/shared" },
    { "path": "../packages/database" }
  ]
}

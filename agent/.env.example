# Anthropic API
ANTHROPIC_API_KEY=

# MCP Server
MCP_SERVER_URL=http://localhost:3001/mcp

# Privy
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_AUTHORIZATION_KEY=

# Database
DATABASE_URL=

# Blockchain
RPC_URL=

# x402
X402_FACILITATOR_URL=https://x402.org/facilitator

# EAS (Ethereum Attestation Service)
EAS_SIGNER_PRIVATE_KEY=    # オフチェーン署名用の秘密鍵
EAS_SCHEMA_UID=            # Base Sepolia にデプロイ済みのスキーマ UID

# Server
PORT=3002

# Service-to-service auth（web の AGENT_SERVICE_TOKEN と同じ値を設定）
# 未設定時、非 production では認証をスキップし、production では全リクエストを拒否する
AGENT_SERVICE_TOKEN=